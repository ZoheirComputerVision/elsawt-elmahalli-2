generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Wilaya {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  code      Int      @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dairas Daira[]

  @@map("wilayas")
}

model Daira {
  id        String   @id @default(cuid())
  name      String
  slug      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  wilayaId String @map("wilaya_id")
  wilaya   Wilaya @relation(fields: [wilayaId], references: [id])

  communes Commune[]

  @@unique([wilayaId, slug])
  @@map("dairas")
}

model Commune {
  id        String   @id @default(cuid())
  name      String
  slug      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dairaId String @map("daira_id")
  daira   Daira  @relation(fields: [dairaId], references: [id])

  news       News[]
  directories DirectoryEntry[]
  ads        Ad[]
  reporters  User[]

  @@unique([dairaId, slug])
  @@map("communes")
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  news      News[]

  @@map("regions")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  news      News[]

  @@map("categories")
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String?
  body        String?
  status      String    @default("draft")
  viewCount   Int       @default(0) @map("view_count")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  regionId  String?  @map("region_id")
  region    Region?  @relation(fields: [regionId], references: [id])
  communeId String?  @map("commune_id")
  commune   Commune? @relation(fields: [communeId], references: [id])

  createdById String? @map("created_by_id")
  createdBy   User?   @relation(fields: [createdById], references: [id])

  media Media[]
  tags  NewsTag[]

  @@map("news")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  news      NewsTag[]

  @@map("tags")
}

model NewsTag {
  newsId String @map("news_id")
  tagId  String @map("tag_id")
  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([newsId, tagId])
  @@map("news_tags")
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  url          String
  newsId       String?  @map("news_id")
  news         News?    @relation(fields: [newsId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("media")
}

enum Role {
  ADMIN
  EDITOR
  REPORTER

  @@map("roles")
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  avatar       String?
  bio          String?
  specialization String?
  phone        String?
  role         Role      @default(REPORTER)
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  communeId String?  @map("commune_id")
  commune   Commune? @relation(fields: [communeId], references: [id])

  news      News[]
  actions   AuditLog[]
  reports   Report[]

  @@map("users")
}

model DirectoryEntry {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?
  phone       String?
  email       String?
  website     String?
  address     String?
  city        String?
  province    String?
  imageUrl    String?  @map("image_url")
  status      String   @default("active")
  featured    Boolean  @default(false)
  contactName String?  @map("contact_name")
  communeId   String?  @map("commune_id")
  commune     Commune? @relation(fields: [communeId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("directory_entries")
}

model Ad {
  id        String   @id @default(cuid())
  title     String
  content   String?
  imageUrl  String?  @map("image_url")
  linkUrl   String?  @map("link_url")
  position  String   @default("sidebar")
  status    String   @default("active")
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  clicks    Int      @default(0)
  views     Int      @default(0)
  communeId String?  @map("commune_id")
  commune   Commune? @relation(fields: [communeId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  adViews AdView[]

  @@map("ads")
}

model AdView {
  id        String   @id @default(cuid())
  viewedAt  DateTime @default(now()) @map("viewed_at")
  adId      String   @map("ad_id")
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@map("ad_views")
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscriptions")
}

model ContactMessage {
  id        String   @id @default(cuid())
  type      String   @default("general")
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Report {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("news_tip")
  status      String   @default("pending")
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("reports")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
